diff --git a/app/notifier/notifier.py b/app/notifier/notifier.py
new file mode 100644
--- /dev/null
+++ b/app/notifier/notifier.py
@@ -0,0 +1,40 @@
+"""
+Notifier module (統合版)
+
+※ LINE Notify は 2025年12月でサービス終了。
+   今後は Slack / Discord / Gmail API などに置き換える前提。
+"""
+
+import os
+import requests
+
+TOKEN = os.getenv("NOTIFY_TOKEN")
+
+def notify(message: str):
+    if not TOKEN:
+        print(f"[NOTIFY] {message}")
+        return
+
+    print(f"[NOTIFY] {message} (TOKEN 使用)")

